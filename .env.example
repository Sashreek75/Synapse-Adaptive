# Synapse Adaptive — your private keys. The app runs fully WITHOUT any of these.
# After editing this file, stop the app (Ctrl+C) and run: npm run dev

NEXT_PUBLIC_APP_URL=http://localhost:3000

# AI brain — Google Gemini (FREE). Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_FAST_MODEL=gemini-2.0-flash

# Google login (Supabase free tier) — Settings > API in your Supabase project
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Payments (Stripe) — Pro $10/mo, Max $25/mo
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_MAX=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Emails (Resend) — https://resend.com
RESEND_API_KEY=
EMAIL_FROM=Synapse Adaptive <onboarding@resend.dev>

# Founder access — set to the exact email you sign in with (Google or manual). Gets Max free.
NEXT_PUBLIC_FOUNDER_EMAILS=support@compliancewatchdog.com

# Admin key for `npm run users` (Supabase → Settings → API → service_role). Keep secret.
SUPABASE_SERVICE_ROLE_KEY=
