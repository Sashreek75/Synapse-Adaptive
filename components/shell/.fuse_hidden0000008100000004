"use client";

import Link from "next/link";
import { usePathname } from "next/navigation";
import { Home, HeartPulse, Activity, CreditCard, Settings, FileText, BookOpen } from "lucide-react";
import { cn } from "@/lib/utils";

/**
 * Navigation, consolidated hard (founding doc): the homepage IS the conversation,
 * so everything else earns its place by helping a health decision.
 *   Home → greeting, today's focus, one insight, the experiment, conversation
 *   Coaching session → the weekly sit-down
 *   Playbook → accumulated understanding + open questions
 *   Profile → the living summary of who you are
 *   Assessments → only when they answer an important question
 */
const groups: { label: string; items: { href: string; label: string; icon: typeof Home; accent?: boolean }[] }[] = [
  {
    label: "Synapse",
    items: [
      { href: "/dashboard", label: "Home", icon: Home },
      { href: "/report", label: "Coaching session", icon: FileText },
      { href: "/playbook", label: "Playbook", icon: BookOpen },
      { href: "/profile", label: "Health profile", icon: HeartPulse },
      { href: "/assessments", label: "Assessments", icon: Activity },
    ],
  },
  {
    label: "Manage",
    items: [
      { href: "/billing", label: "Plan & billing", icon: CreditCard },
      { href: "/settings", label: "Settings", icon: Settings },
    ],
  },
];

const tabBar = [
  { href: "/dashboard", label: "Home", icon: Home },
  { href: "/report", label: "Coaching", icon: FileText },
  { href: "/playbook", label: "Playbook", icon: BookOpen },
  { href: "/profile", label: "Profile", icon: HeartPulse },
];

export function SidebarNav() {
  const pathname = usePathname();
  return (
    <nav className="hidden flex-col gap-1 md:flex">
      {groups.map((g) => (
        <div key={g.label} className="mb-2">
          <p className="px-3 pb-1 pt-2 text-[11px] font-semibold uppercase tracking-wider text-muted/70">{g.label}</p>
          <div className="flex flex-col gap-0.5">
            {g.items.map(({ href, label, icon: Icon, accent }) => {
              const active = pathname === href || pathname.startsWith(`${href}/`);
              return (
                <Link key={href} href={href}
                  className={cn(
                    "group relative flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium transition-all",
                    active ? "bg-navy-900 text-white shadow-soft" : "text-muted hover:bg-surface-2 hover:text-ink",
                  )}>
                  {active && <span className="absolute left-0 top-2 bottom-2 w-1 rounded-full bg-orange-500" />}
                  <Icon className={cn("h-4 w-4 transition-transform group-hover:scale-110", accent && !active && "text-orange-500")} />
                  {label}
                </Link>
              );
            })}
          </div>
        </div>
      ))}
    </nav>
  );
}

export function MobileTabBar() {
  const pathname = usePathname();
  return (
    <nav className="fixed inset-x-0 bottom-0 z-50 grid grid-cols-4 border-t glass md:hidden">
      {tabBar.map(({ href, label, icon: Icon }) => {
        const active = pathname === href || pathname.startsWith(`${href}/`);
        return (
          <Link key={href} href={href} className={cn("flex flex-col items-center gap-1 py-2.5 text-xs", active ? "text-orange-600" : "text-muted")}>
            <Icon className="h-5 w-5" /> {label}
          </Link>
        );
      })}
    </nav>
  );
}
